# =============================================================
# BauLV — Environment Variables for Railway Deployment
# =============================================================
# Copy this to .env for local development.
# On Railway, set these in the service's "Variables" tab.
# =============================================================

# ---- REQUIRED ----

# Database (auto-set by Railway when you add the Postgres plugin)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# JWT secret — generate a secure random string (32+ chars)
# Run: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=your-secret-here

# ---- OPTIONAL (features disabled if blank) ----

# Anthropic Claude API key — needed for AI features (plan analysis, chat, text generation)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — needed for paid subscription checkout (all plans are free for now)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIS=price_...
STRIPE_PRICE_PRO=price_...

# ---- DEPLOYMENT (auto-set by Railway) ----

# Railway sets PORT automatically — do NOT override
# PORT=8000

# Frontend URL (for CORS). Set to your Railway public domain:
FRONTEND_URL=https://your-app.up.railway.app
